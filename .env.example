# ============================================
# Ready2Spray Open Source - Environment Config
# ============================================
# Copy this file to .env and customize as needed
# The setup.sh script will do this automatically

# --- Database (auto-configured by Docker Compose) ---
POSTGRES_USER=ready2spray
POSTGRES_PASSWORD=ready2spray_local_2024
POSTGRES_DB=ready2spray

# --- Authentication ---
# Auto-generated by setup.sh - change for production
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_STRING_AT_LEAST_32_CHARS
VITE_DEV_AUTH=true

# --- AI / LLM (defaults to local Ollama - no API key needed) ---
LLM_PROVIDER=ollama
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=qwen3.5:4b
# Optional: Use Anthropic Claude instead (requires API key)
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-api03-...

# --- Google Maps (optional - enables satellite maps & geocoding) ---
# Get your key: https://console.cloud.google.com/apis/credentials
# Enable: Maps JavaScript API, Geocoding API, Places API, Directions API
GOOGLE_MAPS_API_KEY=

# --- FieldPulse Integration (optional) ---
# Get your API key from FieldPulse dashboard > Settings > API
# FIELDPULSE_API_KEY=

# --- Zoho CRM Integration (optional) ---
# Register at: https://api-console.zoho.com/
# ZOHO_CLIENT_ID=
# ZOHO_CLIENT_SECRET=

# --- App Settings ---
VITE_APP_TITLE=Ready2Spray AI
VITE_APP_ID=ready2spray-local
NODE_ENV=development
PORT=3000

# --- Optional Services (not required for local use) ---
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# VITE_STRIPE_PUBLISHABLE_KEY=
# MAILGUN_API_KEY=
# MAILGUN_DOMAIN=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=
# AWS_S3_BUCKET=
